#!/bin/bash

# Usage: ./sync-env.sh user@host.local VAR1 VAR2 VAR3
CONN_STR=$1
shift
VARS=("$@")

if [[ -z "$CONN_STR" ]]; then
    echo "Usage: $0 user@host.local VAR1 VAR2 ..."
    exit 1
fi

LOCAL_FILE=".bash-local-env"
REMOTE_PATH="~/$LOCAL_FILE"

echo "--- Generating local environment file ---"
echo "# Generated by sync-env on $(date)" > "$LOCAL_FILE"

for VAR in "${VARS[@]}"; do
    if [[ -n "${!VAR}" ]]; then
        echo "export $VAR=\"${!VAR}\"" >> "$LOCAL_FILE"
        echo "Added: $VAR"
    else
        echo "Warning: $VAR is not set on host, skipping."
    fi
done

echo "--- Ensuring .bashrc sources $LOCAL_FILE ---"
# This check prevents double-entry in .bashrc
LINE="[[ -f $REMOTE_PATH ]] && source $REMOTE_PATH"
ssh -o StrictHostKeyChecking=no "$CONN_STR" "grep -qxF '$LINE' ~/.bashrc || echo '$LINE' >> ~/.bashrc"

echo "--- Copying file to VM ---"
scp -o StrictHostKeyChecking=no "$LOCAL_FILE" "$CONN_STR:$REMOTE_PATH"

echo "--- Success ---"
rm "$LOCAL_FILE"
