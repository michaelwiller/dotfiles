#!/bin/bash
#
# qvm - QEMU VM Cluster Manager
# A lightweight Vagrant-like tool using QEMU directly
#

set -e

# Activate homebin venv if available
VENV="${HOMEBIN_VENV:-$HOME/.venv/homebin}"
if [[ -f "$VENV/bin/activate" ]]; then
  source "$VENV/bin/activate"
fi

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLUSTER_DIR="${CLUSTER_DIR:-$PWD}"
CONFIG_FILE="$CLUSTER_DIR/qvm-config.yaml"
SYNCED_VARS_FILE=".synced-vars"
SHARED_IMAGES_DIR="${HOME}/.qvm/images"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log() {
    echo -e "${GREEN}[$(date +'%Y-%m-%d %H:%M:%S')]${NC} $*" >&2
}

error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $*" >&2
}

info() {
    echo -e "${BLUE}[INFO]${NC} $*" >&2
}

usage() {
    cat << EOF
qvm - QEMU VM Cluster Manager

USAGE:
    qvm <command> [options]

COMMANDS:
    init <cluster-name>          Initialize a new cluster directory
    start [vm-name]              Start cluster or specific VM
    stop [vm-name]               Stop cluster or specific VM
    status                       Show cluster status
    ssh <vm-name>                SSH into a VM
    sync-vars                    Sync environment variables to VMs
    provision <vm-name>          Provision a VM (create disk + inject SSH keys)
    destroy <vm-name>|all       Destroy a VM or all VMs (delete disk)
    ssh-key                    Show cluster SSH private key for manual access

CONFIGURATION:
    Cluster config: $CONFIG_FILE
    Cluster directory: $CLUSTER_DIR
    Shared images: $HOME/.qvm/images

EXAMPLE CONFIG (qvm-config.yaml):
    cluster:
      name: my-cluster
      base_image: ubuntu-22.04-arm64.qcow2  # Place in ~/.qvm/images/ or cluster images/
      arch: arm64
      vms:
        - name: vm1
          cpus: 2
          memory: 4G
          disk_size: 20G
          # Optional: if you use bridged networking you can set a static IP here
          # ip_address: 192.168.1.101
          # Optional: specify SSH user (default: qemu for cloud images, ubuntu for Ubuntu)
          # ssh_user: ubuntu
          # Optional: override SSH port (default: derived from ports or 22)
          # ssh_port: 2222
          # Optional: path to custom provision script (run after SSH key injection)
          # provision_script: ./provision-scripts/setup-vm1.sh
          shared_folders:
            - host: ./shared
              guest: /shared
          ports:
            - host: 2222
              guest: 22
      synced_vars:
        - HOME
        - USER
        - PATH

EOF
}

check_dependencies() {
    local deps=("qemu-system-aarch64" "qemu-system-x86_64" "qemu-img" "ssh" "scp" "python3")
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" >/dev/null 2>&1; then
            error "Missing dependency: $dep"
            exit 1
        fi
    done

    # Ensure pyyaml is available for config parsing
    if ! python3 -c 'import yaml' >/dev/null 2>&1; then
        error "Python module 'pyyaml' is required."
        error "Install it with: python3 -m pip install --user pyyaml"
        exit 1
    fi
}

load_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        error "Config file not found: $CONFIG_FILE"
        exit 1
    fi

    # Use python to parse YAML since it's available
    if command -v python3 >/dev/null 2>&1; then
        CLUSTER_NAME=$(python3 -c "import yaml; print(yaml.safe_load(open('$CONFIG_FILE'))['cluster']['name'])")
        BASE_IMAGE=$(python3 -c "import yaml; print(yaml.safe_load(open('$CONFIG_FILE'))['cluster']['base_image'])")
        ARCH=$(python3 -c "import yaml; print(yaml.safe_load(open('$CONFIG_FILE'))['cluster']['arch'])")
    else
        error "python3 required for YAML parsing"
        exit 1
    fi
}

get_qemu_cmd() {
    case "$ARCH" in
        arm64|aarch64)
            echo "qemu-system-aarch64"
            ;;
        amd64|x86_64)
            echo "qemu-system-x86_64"
            ;;
        *)
            error "Unsupported architecture: $ARCH"
            exit 1
            ;;
    esac
}

get_vm_config() {
    local vm_name="$1"
    local key="$2"

    python3 -c "
import yaml
config = yaml.safe_load(open('$CONFIG_FILE'))
vms = config['cluster']['vms']
vm = next((v for v in vms if v['name'] == '$vm_name'), None)
if vm and '$key' in vm:
    print(vm['$key'])
else:
    print('')
"
}

get_vm_ssh_host() {
    local vm_name="$1"
    local ip=$(get_vm_config "$vm_name" "ip_address")
    if [[ -n "$ip" ]]; then
        echo "$ip"
        return
    fi
    # Default to localhost for port-forwarded VMs
    echo "127.0.0.1"
}

get_vm_ssh_user() {
    local vm_name="$1"
    local user=$(get_vm_config "$vm_name" "ssh_user")
    if [[ -n "$user" ]]; then
        echo "$user"
        return
    fi
    echo "qemu"
}

get_vm_ssh_port() {
    local vm_name="$1"

    # Explicit SSH port override
    local ssh_port=$(get_vm_config "$vm_name" "ssh_port")
    if [[ -n "$ssh_port" ]]; then
        echo "$ssh_port"
        return
    fi

    # Fallback to port-forwarding config (guest 22)
    local ports=$(get_vm_config "$vm_name" "ports")
    if [[ -n "$ports" ]]; then
        python3 -c "
import yaml
config = yaml.safe_load(open('$CONFIG_FILE'))
vms = config['cluster']['vms']
vm = next((v for v in vms if v['name'] == '$vm_name'), None)
if vm and 'ports' in vm:
    for port in vm['ports']:
        if port.get('guest') == 22:
            print(port.get('host', 22))
            break
"
    fi

    # Default to 22 if not configured
    echo "22"
}

create_vm_disk() {
    local vm_name="$1"
    local disk_size=$(get_vm_config "$vm_name" "disk_size")

    if [[ -z "$disk_size" ]]; then
        disk_size="20G"
    fi

    local disk_path="$CLUSTER_DIR/images/${vm_name}.qcow2"
    local base_image=""

    # Check shared images directory first
    if [[ -f "$SHARED_IMAGES_DIR/$BASE_IMAGE" ]]; then
        base_image="$SHARED_IMAGES_DIR/$BASE_IMAGE"
    elif [[ -f "$CLUSTER_DIR/images/$BASE_IMAGE" ]]; then
        base_image="$CLUSTER_DIR/images/$BASE_IMAGE"
    else
        error "Base image not found in shared ($SHARED_IMAGES_DIR) or cluster ($CLUSTER_DIR/images) directories: $BASE_IMAGE"
        exit 1
    fi

    if [[ ! -f "$disk_path" ]]; then
        info "Creating VM disk: $disk_path ($disk_size) from $base_image"
        qemu-img create -f qcow2 -b "$base_image" "$disk_path" "$disk_size"
    fi
}

generate_cluster_ssh_key() {
    local key_path="$CLUSTER_DIR/ssh/cluster_key"

    if [[ ! -f "${key_path}" ]]; then
        info "Generating cluster SSH key pair"
        mkdir -p "$CLUSTER_DIR/ssh"
        ssh-keygen -t ed25519 -f "${key_path}" -N "" -C "qvm-cluster-${CLUSTER_NAME}"
        info "SSH key generated: ${key_path}"
    else
        info "Cluster SSH key already exists: ${key_path}"
    fi

    echo "${key_path}"
}

inject_ssh_key_into_vm() {
    local vm_name="$1"
    local key_path="$2"
    local disk_path="$CLUSTER_DIR/images/${vm_name}.qcow2"
    local user=$(get_vm_config "$vm_name" "ssh_user")

    if [[ -z "$user" ]]; then
        user="qemu"  # Default user for cloud images
    fi

    if [[ ! -f "$disk_path" ]]; then
        error "VM disk not found: $disk_path"
        return 1
    fi

    if [[ ! -f "${key_path}.pub" ]]; then
        error "SSH public key not found: ${key_path}.pub"
        return 1
    fi

    info "Injecting SSH key into VM: $vm_name (user: $user)"

    # Use qemu-nbd to mount the QCOW2 image
    local nbd_device="/dev/nbd0"
    local mount_point="/tmp/qvm-mount-${vm_name}"

    # Load nbd module if not loaded
    if ! lsmod | grep -q nbd; then
        sudo modprobe nbd max_part=8
    fi

    # Find an available nbd device
    for i in {0..7}; do
        nbd_device="/dev/nbd${i}"
        if [[ ! -b "$nbd_device" ]]; then
            continue
        fi
        if ! sudo qemu-nbd -c "$nbd_device" "$disk_path" 2>/dev/null; then
            continue
        fi
        break
    done

    if [[ $? -ne 0 ]]; then
        error "Failed to connect QCOW2 to NBD device"
        return 1
    fi

    # Wait for partitions to be recognized
    sleep 2

    # Find the root partition (usually p1 for Ubuntu cloud images)
    local root_partition=""
    for part in "${nbd_device}p1" "${nbd_device}p2" "${nbd_device}1" "${nbd_device}2"; do
        if [[ -b "$part" ]]; then
            root_partition="$part"
            break
        fi
    done

    if [[ -z "$root_partition" ]]; then
        error "Could not find root partition on $nbd_device"
        sudo qemu-nbd -d "$nbd_device"
        return 1
    fi

    # Mount the partition
    sudo mkdir -p "$mount_point"
    if ! sudo mount "$root_partition" "$mount_point"; then
        error "Failed to mount $root_partition"
        sudo qemu-nbd -d "$nbd_device"
        return 1
    fi

    # Inject the SSH key
    sudo mkdir -p "$mount_point/home/$user/.ssh"
    sudo cp "${key_path}.pub" "$mount_point/home/$user/.ssh/authorized_keys"
    sudo chown -R 1000:1000 "$mount_point/home/$user/.ssh"
    sudo chmod 700 "$mount_point/home/$user/.ssh"
    sudo chmod 600 "$mount_point/home/$user/.ssh/authorized_keys"

    # Also add to root's authorized_keys for convenience
    sudo mkdir -p "$mount_point/root/.ssh"
    sudo cp "${key_path}.pub" "$mount_point/root/.ssh/authorized_keys"
    sudo chmod 700 "$mount_point/root/.ssh"
    sudo chmod 600 "$mount_point/root/.ssh/authorized_keys"

    # Unmount and disconnect
    sudo umount "$mount_point"
    sudo rmdir "$mount_point"
    sudo qemu-nbd -d "$nbd_device"

    info "SSH key injected successfully into $vm_name"
}

run_provision_script() {
    local vm_name="$1"
    local script_path="$2"
    local host=$(get_vm_ssh_host "$vm_name")
    local port=$(get_vm_ssh_port "$vm_name")
    local user=$(get_vm_ssh_user "$vm_name")

    if [[ ! -f "$script_path" ]]; then
        error "Provision script not found: $script_path"
        return 1
    fi

    info "Running provision script: $script_path on $vm_name"

    # Copy script to VM
    scp -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -P "$port" "$script_path" "${user}@${host}:/tmp/provision-script.sh"

    # Make it executable and run it
    ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p "$port" "${user}@${host}" "chmod +x /tmp/provision-script.sh && /tmp/provision-script.sh"

    # Clean up
    ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p "$port" "${user}@${host}" "rm /tmp/provision-script.sh"

    info "Provision script completed on $vm_name"
}

provision_vm() {
    local vm_name="$1"

    info "Provisioning VM: $vm_name"

    # Create the VM disk
    create_vm_disk "$vm_name"

    # Generate cluster SSH key if needed
    local key_path=$(generate_cluster_ssh_key)

    # Inject SSH key into the VM
    inject_ssh_key_into_vm "$vm_name" "$key_path"

    # Run custom provisioning script if specified
    local provision_script=$(get_vm_config "$vm_name" "provision_script")
    if [[ -n "$provision_script" ]]; then
        run_provision_script "$vm_name" "$provision_script"
    fi

    info "VM $vm_name provisioned successfully"
}

build_qemu_args() {
    local vm_name="$1"
    local args=()

    local cpus=$(get_vm_config "$vm_name" "cpus")
    local memory=$(get_vm_config "$vm_name" "memory")
    local disk_path="$CLUSTER_DIR/images/${vm_name}.qcow2"

    # Basic args
    args+=(-name "$vm_name")
    args+=(-machine virt,accel=hvf)  # Use Hypervisor.framework on macOS
    args+=(-cpu host)
    args+=(-smp "$cpus")
    args+=(-m "$memory")

    # Disk
    args+=(-drive "file=$disk_path,if=virtio,format=qcow2")

    # Network
    args+=(-netdev "user,id=net0")
    args+=(-device "virtio-net-pci,netdev=net0")

    # Ports
    local ports=$(get_vm_config "$vm_name" "ports")
    if [[ -n "$ports" ]]; then
        python3 -c "
import yaml
config = yaml.safe_load(open('$CONFIG_FILE'))
vms = config['cluster']['vms']
vm = next((v for v in vms if v['name'] == '$vm_name'), None)
if vm and 'ports' in vm:
    for port in vm['ports']:
        host_port = port.get('host')
        guest_port = port.get('guest')
        if host_port and guest_port:
            print(f'-netdev user,id=net0,hostfwd=tcp::{host_port}-:{guest_port}')
            break
" | while read -r netdev_arg; do
            if [[ -n "$netdev_arg" ]]; then
                args+=("$netdev_arg")
                break
            fi
        done
    fi

    # Shared folders
    local shared_folders=$(get_vm_config "$vm_name" "shared_folders")
    if [[ -n "$shared_folders" ]]; then
        local idx=0
        python3 -c "
import yaml
config = yaml.safe_load(open('$CONFIG_FILE'))
vms = config['cluster']['vms']
vm = next((v for v in vms if v['name'] == '$vm_name'), None)
if vm and 'shared_folders' in vm:
    for sf in vm['shared_folders']:
        print(f'{sf[\"host\"]}:{sf[\"guest\"]}')
" | while IFS=: read -r host_path guest_path; do
            if [[ -n "$host_path" && -n "$guest_path" ]]; then
                args+=(-virtfs "local,path=$host_path,mount_tag=host$idx,security_model=mapped,id=host$idx")
                ((idx++))
            fi
        done
    fi

    # Display (none for headless)
    args+=(-nographic)
    args+=(-serial mon:stdio)

    echo "${args[@]}"
}

start_vm() {
    local vm_name="$1"

    if is_vm_running "$vm_name"; then
        warn "VM $vm_name is already running"
        return
    fi

    info "Starting VM: $vm_name"

    create_vm_disk "$vm_name"

    local qemu_cmd=$(get_qemu_cmd)
    local qemu_args=$(build_qemu_args "$vm_name")

    # Start in background
    nohup $qemu_cmd $qemu_args > "$CLUSTER_DIR/logs/${vm_name}.log" 2>&1 &
    local pid=$!

    echo $pid > "$CLUSTER_DIR/pids/${vm_name}.pid"

    # Wait a bit for VM to boot
    sleep 5

    info "VM $vm_name started (PID: $pid)"
}

stop_vm() {
    local vm_name="$1"

    if ! is_vm_running "$vm_name"; then
        warn "VM $vm_name is not running"
        return
    fi

    local pid_file="$CLUSTER_DIR/pids/${vm_name}.pid"
    local pid=$(cat "$pid_file")

    info "Stopping VM: $vm_name (PID: $pid)"

    kill "$pid" 2>/dev/null || true
    rm -f "$pid_file"

    # Try graceful shutdown first
    local host=$(get_vm_ssh_host "$vm_name")
    local port=$(get_vm_ssh_port "$vm_name")
    local user=$(get_vm_ssh_user "$vm_name")

    if [[ -n "$port" ]]; then
        sleep 2
        ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
            -p "$port" "${user}@${host}" "sudo shutdown now" 2>/dev/null || true
        sleep 10
    fi

    # Force kill if still running
    if kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null || true
    fi

    info "VM $vm_name stopped"
}

is_vm_running() {
    local vm_name="$1"
    local pid_file="$CLUSTER_DIR/pids/${vm_name}.pid"

    if [[ ! -f "$pid_file" ]]; then
        return 1
    fi

    local pid=$(cat "$pid_file")
    if kill -0 "$pid" 2>/dev/null; then
        return 0
    else
        rm -f "$pid_file"
        return 1
    fi
}

sync_vars() {
    local vm_name="$1"
    local host=$(get_vm_ssh_host "$vm_name")
    local port=$(get_vm_ssh_port "$vm_name")
    local user=$(get_vm_ssh_user "$vm_name")

    if [[ -z "$port" ]]; then
        error "No SSH port configured for VM: $vm_name"
        return 1
    fi

    # Get synced vars from config
    local synced_vars=$(python3 -c "
import yaml
config = yaml.safe_load(open('$CONFIG_FILE'))
if 'synced_vars' in config['cluster']:
    print('\n'.join(config['cluster']['synced_vars']))
")

    # Create synced vars file
    local vars_file="$CLUSTER_DIR/$SYNCED_VARS_FILE"
    rm -f "$vars_file"

    echo "# Synced environment variables - $(date)" > "$vars_file"

    while IFS= read -r var_name; do
        if [[ -n "$var_name" && -n "${!var_name}" ]]; then
            echo "export $var_name=\"${!var_name}\"" >> "$vars_file"
        fi
    done <<< "$synced_vars"

    # Copy to VM
    scp -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -P "$port" "$vars_file" "${user}@${host}:/home/${user}/$SYNCED_VARS_FILE"

    info "Synced variables to VM: $vm_name"
}

ssh_vm() {
    local vm_name="$1"
    local host=$(get_vm_ssh_host "$vm_name")
    local port=$(get_vm_ssh_port "$vm_name")
    local user=$(get_vm_ssh_user "$vm_name")

    if [[ -z "$port" ]]; then
        error "No SSH port configured for VM: $vm_name"
        exit 1
    fi

    info "SSH into VM: $vm_name ($user@$host:$port)"
    ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p "$port" "${user}@${host}"
}

init_cluster() {
    local cluster_name="$1"

    if [[ -z "$cluster_name" ]]; then
        error "Cluster name required"
        exit 1
    fi

    if [[ -d "$cluster_name" ]]; then
        error "Directory $cluster_name already exists"
        exit 1
    fi

    info "Initializing cluster: $cluster_name"

    mkdir -p "$cluster_name"/{images,shared,logs,pids}
    mkdir -p "$SHARED_IMAGES_DIR"

    cat > "$cluster_name/qvm-config.yaml" << 'EOF'
cluster:
  name: CLUSTER_NAME
  base_image: ubuntu-22.04-arm64.qcow2
  arch: arm64
  vms:
    - name: vm1
      cpus: 2
      memory: 4G
      disk_size: 20G
      # Optional: if you use bridged networking you can set a static IP here
      # ip_address: 192.168.1.101
      # Optional: specify SSH user (default: qemu)
      # ssh_user: ubuntu
      # Optional: override SSH port (default: derived from ports or 22)
      # ssh_port: 2222
      shared_folders:
        - host: ./shared
          guest: /shared
      ports:
        - host: 2222
          guest: 22
  synced_vars:
    - HOME
    - USER
    - PATH
EOF

    sed -i '' "s/CLUSTER_NAME/$cluster_name/" "$cluster_name/qvm-config.yaml"

    info "Cluster initialized. Place base images in $SHARED_IMAGES_DIR or cluster images/ directory"
}

list_vms() {
    python3 -c "
import yaml
config = yaml.safe_load(open('$CONFIG_FILE'))
vms = config['cluster']['vms']
for vm in vms:
    print(vm['name'])
"
}

show_status() {
    echo "Cluster: $CLUSTER_NAME"
    echo "Architecture: $ARCH"
    echo "Base Image: $BASE_IMAGE"
    echo ""
    echo "VMs:"

    list_vms | while read -r vm_name; do
        if is_vm_running "$vm_name"; then
            echo "  $vm_name: RUNNING"
        else
            echo "  $vm_name: STOPPED"
        fi
    done
}

show_cluster_ssh_key() {
    local key_path="$CLUSTER_DIR/ssh/cluster_key"

    if [[ ! -f "$key_path" ]]; then
        error "Cluster SSH key not found. Run 'qvm provision <vm-name>' first to generate it."
        exit 1
    fi

    echo "Cluster SSH private key: $key_path"
    echo ""
    echo "To use this key for SSH access:"
    echo "  ssh -i $key_path <user>@<host> -p <port>"
    echo ""
    echo "Or add to your SSH agent:"
    echo "  ssh-add $key_path"
    echo ""
    echo "Private key contents:"
    echo "-----BEGIN OPENSSH PRIVATE KEY-----"
    cat "$key_path"
    echo "-----END OPENSSH PRIVATE KEY-----"
}

# Main command handling
main() {
    check_dependencies

    case "${1:-help}" in
        init)
            init_cluster "$2"
            ;;
        start)
            load_config
            if [[ -n "$2" ]]; then
                start_vm "$2"
            else
                list_vms | while read -r vm_name; do
                    start_vm "$vm_name"
                done
            fi
            ;;
        stop)
            load_config
            if [[ -n "$2" ]]; then
                stop_vm "$2"
            else
                list_vms | while read -r vm_name; do
                    stop_vm "$vm_name"
                done
            fi
            ;;
        status)
            load_config
            show_status
            ;;
        ssh)
            load_config
            if [[ -z "$2" ]]; then
                # vagrant-style: if only one VM is configured, default to it
                vm_name=$(list_vms | head -n1)
                if [[ -z "$vm_name" ]]; then
                    error "No VMs configured"
                    exit 1
                fi
            else
                vm_name="$2"
            fi
            ssh_vm "$vm_name"
            ;;
        sync-vars)
            load_config
            if [[ -n "$2" ]]; then
                sync_vars "$2"
            else
                list_vms | while read -r vm_name; do
                    sync_vars "$vm_name"
                done
            fi
            ;;
        provision)
            load_config
            provision_vm "$2"
            ;;
        destroy)
            load_config
            if [[ "$2" == "all" ]]; then
                info "Destroying all VMs in cluster"
                list_vms | while read -r vm_name; do
                    destroy_vm "$vm_name"
                done
                # Also remove cluster SSH keys
                if [[ -d "$CLUSTER_DIR/ssh" ]]; then
                    info "Removing cluster SSH keys"
                    rm -rf "$CLUSTER_DIR/ssh"
                fi
            else
                destroy_vm "$2"
            fi
            ;;
        list)
            load_config
            list_vms
            ;;
        ssh-key)
            load_config
            show_cluster_ssh_key
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            error "Unknown command: $1"
            usage
            exit 1
            ;;
    esac
}

destroy_vm() {
    local vm_name="$1"
    local disk_path="$CLUSTER_DIR/images/${vm_name}.qcow2"

    if [[ -f "$disk_path" ]]; then
        info "Destroying VM disk: $disk_path"
        rm -f "$disk_path"
    else
        warn "VM disk not found: $disk_path"
    fi
}

main "$@"